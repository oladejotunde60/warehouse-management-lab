# Copy this file to .env.local and fill in.
# All values come from Supabase project settings (see README).

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...

# --- Email via Resend (optional) ---
# Without this, OTPs and receipts are still shown in the UI but no real emails go out.
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- App ---
# In production this is your Vercel URL, e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
